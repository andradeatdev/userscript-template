{
  "name": "pixeldrain-tweaks",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && rollup -c",
    "watch": "concurrently \"tsc --noEmit --watch --preserveWatchOutput\" \"rollup -c -w\"",
    "validate": "tsc --noEmit"
  },
  "private": true,
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-typescript": "^8.0.1",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/bun": "latest",
    "concurrently": "^10.0.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
