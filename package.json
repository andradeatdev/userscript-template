{
  "name": "pixeldrain-tweaks",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && rollup -c",
    "watch": "concurrently \"tsc --noEmit --watch --preserveWatchOutput\" \"rollup -c -w\"",
    "validate": "tsc --noEmit"
  },
  "private": true,
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-typescript": "^8.0.1",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@types/bun": "latest",
    "@violentmonkey/types": "^0.3.3",
    "concurrently": "^10.0.3",
    "rollup": "^4.62.2",
    "rollup-plugin-userscript-meta": "^1.0.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/node": "^26.1.1"
  }
}
